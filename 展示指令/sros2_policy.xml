<?xml version="1.0" encoding="UTF-8"?>
<!-- SROS2 存取控制政策 — 合法節點放行（含 FastDDS 探索 topic ros_discovery_info）。
     目前用 wildcard 全放行，先讓「身分驗證+加密+擋攻擊機」成立；
     細粒度 ACL（限定各節點只能讀寫特定 topic）列為階段二後續強化。 -->
<policy version="0.2.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://download.ros.org/schema/policy.xsd">
  <enclaves>
    <enclave path="/talker">
      <profiles>
        <profile ns="/" node="talker">
          <topics publish="ALLOW"><topic>*</topic></topics>
          <topics subscribe="ALLOW"><topic>*</topic></topics>
          <services reply="ALLOW"><service>*</service></services>
          <services request="ALLOW"><service>*</service></services>
        </profile>
      </profiles>
    </enclave>
    <enclave path="/listener">
      <profiles>
        <profile ns="/" node="listener">
          <topics publish="ALLOW"><topic>*</topic></topics>
          <topics subscribe="ALLOW"><topic>*</topic></topics>
          <services reply="ALLOW"><service>*</service></services>
          <services request="ALLOW"><service>*</service></services>
        </profile>
      </profiles>
    </enclave>
